# ============================================================
#  PORTFOLIO - Environment Variables Template
#  This file is safe to commit to Git.
#  Copy to .env.local and fill in your real credentials.
# ============================================================

# Site Config
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SITE_NAME=

# Owner Info
NEXT_PUBLIC_OWNER_NAME=
NEXT_PUBLIC_OWNER_EMAIL=
NEXT_PUBLIC_OWNER_PHONE=
NEXT_PUBLIC_OWNER_LOCATION=

# Social Links
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_TWITTER_URL=

# EmailJS (https://www.emailjs.com)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
